# FiveNursings Environment Variables Template
# Copy this file to .env and fill in the values.
# Do NOT commit the actual .env file to version control.

# --- AI Services (OpenRouter) ---
# Used by both Backend (Node.js) and Frontend (Vite)
OPENROUTER_API_KEY=your_openrouter_key_here
VITE_OPENROUTER_API_KEY=your_openrouter_key_here

# --- AI Services (Google Gemini) ---
# Used by Frontend (Vite)
VITE_GEMINI_API_KEY=your_gemini_key_here

# --- Design Note ---
# The project uses a single root .env as the Source of Truth.
# Subdirectories (admin/, user/) use symbolic links to this file.
# To set up locally:
# 1. cp .env.example .env
# 2. ln -s ../.env admin/.env
# 3. ln -s ../.env user/.env
