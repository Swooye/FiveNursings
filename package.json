{
  "name": "fivenursings-admin",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build --prefix user && npm run build --prefix admin",
    "build:functions": "npm run build --prefix functions",
    "lint": "eslint .",
    "preview": "vite preview",
    "user": "npm --prefix user run dev",
    "admin": "npm --prefix admin run dev -- --port 5174",
    "backend": "npm --prefix server start",
    "start": "bash start-dev.sh"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "antd": "^6.2.3",
    "lucide-react": "^0.563.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "firebase-tools": "^15.11.0",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^5.4.11"
  },
  "workspaces": [
    "server",
    "user",
    "admin",
    "app",
    "functions"
  ]
}
